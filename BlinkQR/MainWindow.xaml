<Window x:Class="BlinkQR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BlinkQR.Converters"
        Title="BlinkQR">

    <Window.Resources>
        <converters:ByteArrayToBitmapImageConverter x:Key="ByteArrayToBitmapImageConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <!-- camera preview -->
            <RowDefinition Height="Auto" />
            <!-- scan result -->
            <RowDefinition Height="Auto" />
            <!-- button -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="20">
            <Image Source="{Binding CameraPreviewData, Converter={StaticResource ByteArrayToBitmapImageConverter}}"
               Stretch="Uniform"/>
        </Border>

        <TextBlock Grid.Row="1"
               Text="{Binding ScanResult}"
               FontSize="24"
               TextAlignment="Center"
               TextWrapping="Wrap"
               Margin="20"/>

        <Button Grid.Row="2"
            Content="Scan QR"
            Width="120"
            Height="40"
            HorizontalAlignment="Center"
            Margin="20"
            Click="StartScan_Click"/>
    </Grid>
</Window>
