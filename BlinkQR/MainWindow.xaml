<Window x:Class="BlinkQR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BlinkQR.Converters"
        Title="BlinkQR">

    <Window.Resources>
        <converters:ByteArrayToBitmapImageConverter x:Key="ByteArrayToBitmapImageConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: Camera -->
        <Border Grid.Column="0" Margin="20">
            <Image Source="{Binding CameraPreviewData, Converter={StaticResource ByteArrayToBitmapImageConverter}}"
               Stretch="Uniform"/>
        </Border>

        <!-- RIGHT SIDE: History -->
        <StackPanel Grid.Column="1" Margin="20">

            <TextBlock Text="Scan History"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="0,0,0,10"/>

            <ListBox ItemsSource="{Binding ScanHistory}"
                 Height="400"/>

            <Button Content="Scan QR"
                Width="120"
                Height="40"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                Click="StartScan_Click"/>
        </StackPanel>
    </Grid>
</Window>
