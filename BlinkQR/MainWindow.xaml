<Window x:Class="BlinkQR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlinkQR"
        Height="450"
        Width="800">

    <Grid>
        <StackPanel VerticalAlignment="Center"
            HorizontalAlignment="Center">

            <TextBlock Text="{Binding ScanResult}"
               FontSize="16"
               TextAlignment="Center"
               Width="400"
               TextWrapping="Wrap"
               Margin="0,0,0,12"/>

            <Button Content="Scan QR"
            Width="120"
            Height="40"
            Click="StartScan_Click"/>
        </StackPanel>

    </Grid>
</Window>
