<Window x:Class="BlinkQR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BlinkQR.Converters"
        Title="BlinkQR"
        Height="560"
        Width="800">

    <Window.Resources>
        <converters:ByteArrayToBitmapImageConverter x:Key="ByteArrayToBitmapImageConverter"/>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Width="480"
                    Height="320"
                    Margin="0,0,0,12">
                <Image Source="{Binding CameraPreviewData, Converter={StaticResource ByteArrayToBitmapImageConverter}}"
                       Stretch="Uniform"/>
            </Border>

            <TextBlock Text="{Binding ScanResult}"
                       FontSize="16"
                       TextAlignment="Center"
                       Width="480"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Button Content="Scan QR"
                    Width="120"
                    Height="40"
                    Click="StartScan_Click"/>
        </StackPanel>
    </Grid>
</Window>
