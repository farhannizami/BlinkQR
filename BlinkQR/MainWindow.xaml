<Window x:Class="BlinkQR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BlinkQR.Converters"
        Title="BlinkQR"
        MinWidth="700"
        MinHeight="500">

    <Window.Resources>
        <converters:ByteArrayToBitmapImageConverter
            x:Key="ByteArrayToBitmapImageConverter"/>
    </Window.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <Border Grid.Column="0"
                Margin="0,0,20,0"
                BorderBrush="#444"
                BorderThickness="1">

            <Image Source="{Binding CameraPreviewData,
                            Converter={StaticResource ByteArrayToBitmapImageConverter}}"
                   Stretch="Uniform"/>
        </Border>

        <!-- RIGHT SIDE -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Scan History"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding ScanHistory}"
                     Margin="0,0,0,10"/>

            <TextBlock Grid.Row="2"
               Text="{Binding Status}"
               Margin="0,0,0,10"
               Foreground="#666"
               TextWrapping="Wrap"/>

            <Button Grid.Row="3"
                Content="Scan Again"
                Width="120"
                Height="40"
                HorizontalAlignment="Left"
                Click="StartScan_Click">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility"
                        Value="Visible"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScanning}"
                                 Value="True">
                                <Setter Property="Visibility"
                                Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style> 
            </Button>
        </Grid>
    </Grid>
</Window>